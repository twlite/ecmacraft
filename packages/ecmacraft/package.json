{
    "name": "ecmacraft",
    "version": "0.0.1",
    "description": "Create minecraft plugins with TypeScript",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": "./bin/index.js",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./cli": {
            "import": "./dist/cli/index.js",
            "types": "./dist/cli/index.d.ts"
        },
        "./config": {
            "import": "./dist/config/define-config.js",
            "types": "./dist/config/define-config.d.ts"
        },
        "./spigot": {
            "import": "./dist/spigot.js",
            "types": "./dist/spigot.d.ts"
        }
    },
    "files": [
        "dist",
        "bin"
    ],
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "pnpm build"
    },
    "license": "MIT",
    "author": "Twilight <hello@twlite.dev>",
    "repository": {
        "type": "git",
        "url": "https://github.com/twlite/ecmacraft"
    },
    "devDependencies": {
        "@ecmacraft/tsconfig": "workspace:*",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@ecmacraft/types": "workspace:*",
        "chokidar": "^5.0.0",
        "commander": "^14.0.3",
        "esbuild": "^0.27.3",
        "jszip": "^3.10.1"
    }
}